# Copy to .env.local (gitignored) for local development

# Django API (Docker)
REACT_APP_API_BASE_URL=http://localhost:8000

# Required if backend API_KEY is set (must match exactly)
REACT_APP_API_KEY=

# Dev only: proxy /api via CRA dev server (default on). Set false to call API directly.
REACT_APP_USE_DEV_PROXY=true

# Public site URL — used for canonical links, Open Graph, JSON-LD
# Production: your Netlify URL or custom domain
REACT_APP_SITE_URL=https://your-site.netlify.app

REACT_APP_SITE_NAME=AI News Digest
REACT_APP_SITE_DESCRIPTION=Curated artificial intelligence and technology news for discovery and learning.
