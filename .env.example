# Copy to .env.local (gitignored):  cp .env.example .env.local
#
# ── Local dev with ngrok (recommended if you tunnel Docker :8000) ─────────────
#   1. docker compose up -d web   (in AI_News_Scraper)
#   2. ngrok http 8000            (copy the https://….ngrok-free.dev URL when it changes)
#   3. Set REACT_APP_API_BASE_URL to that URL, REACT_APP_USE_DEV_PROXY=false
#   4. Ensure AI_News_Scraper CORS_ALLOWED_ORIGINS includes http://localhost:3000
#
# ── Local dev without ngrok (CRA proxy → localhost) ───────────────────────────
#   REACT_APP_API_BASE_URL=http://localhost:8000
#   REACT_APP_USE_DEV_PROXY=true

# Active API (no trailing slash)
# ngrok example:
# REACT_APP_API_BASE_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev
REACT_APP_API_BASE_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev

# Must match AI_News_Scraper/.env API_KEY when the API requires X-Api-Key
REACT_APP_API_KEY=

# Public URL of this React app in the browser (local dev)
REACT_APP_SITE_URL=http://localhost:3000

# false = browser calls REACT_APP_API_BASE_URL directly (typical with ngrok)
# true  = CRA dev server proxies /api to REACT_APP_API_BASE_URL (typical with localhost:8000)
REACT_APP_USE_DEV_PROXY=false

# ── Editor: Firebase Google + GitHub (add alongside the vars above) ─────────
# Firebase Console → Project settings → Your apps → Web app config
# Also enable Google + GitHub under Authentication → Sign-in method
# Backend: FIREBASE_PROJECT_ID, FIREBASE_SERVICE_ACCOUNT_JSON, EDITOR_ALLOWED_EMAILS
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Optional: legacy API-key editor login (dev fallback if Firebase is not set up)
REACT_APP_EDITOR_API_KEY=

# ── Production (Netlify) ──────────────────────────────────────────────────────
# REACT_APP_API_BASE_URL=https://your-stable-public-api.example.com
# REACT_APP_SITE_URL=https://your-site.netlify.app
# REACT_APP_USE_DEV_PROXY=   (do not set on Netlify)
# Netlify prebuild fetches sitemap/robots from the API — URL must be up at deploy time

REACT_APP_GA_MEASUREMENT_ID=G-TCT20QCCWS
REACT_APP_SITE_NAME=AI News Repo
REACT_APP_SITE_DESCRIPTION=Curated artificial intelligence and technology news for discovery and learning.

# Partner CTA on article pages (CustomGPT referral — UI only, not injected by LLM)
# REACT_APP_PARTNER_CTA_ENABLED=true
# REACT_APP_PARTNER_FPR=elf67
# REACT_APP_PARTNER_DISCLOSURE=Partner link — we may earn a commission if you sign up.
