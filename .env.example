# Copy to .env.local (gitignored) for local development

# Django API — pick ONE:
#   Local Docker only:  http://localhost:8000
#   ngrok (Netlify demo): https://YOUR-SUBDOMAIN.ngrok-free.app  (from `ngrok http 8000`, no trailing slash)
REACT_APP_API_BASE_URL=http://localhost:8000

# Required if backend API_KEY is set (must match AI_News_Scraper/.env API_KEY exactly)
REACT_APP_API_KEY=
# Same as EDITOR_API_KEY or API_KEY — unlocks http://localhost:3000/editor
REACT_APP_EDITOR_API_KEY=

# Dev only: proxy /api via CRA dev server (default on). With ngrok, true proxies to the tunnel;
# set false to call ngrok directly from the browser (needs CORS for http://localhost:3000).
REACT_APP_USE_DEV_PROXY=true

# Public site URL — used for canonical links, Open Graph, JSON-LD
# Production: your Netlify URL or custom domain
REACT_APP_SITE_URL=https://your-site.netlify.app

REACT_APP_SITE_NAME=AI News Digest
REACT_APP_SITE_DESCRIPTION=Curated artificial intelligence and technology news for discovery and learning.
